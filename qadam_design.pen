                    {
                      "type": "text",
                      "id": "xP7DN",
                      "name": "ws4ContentP1",
                      "fill": "#0F172A",
                      "content": "Remote workers face a banking nightmare. Traditional banks demand a fixed address. Crypto solutions are complex. Nomad bridges the gap — one account, any country, any currency.",

                {
                  "type": "frame",
                  "id": "hmIJ3",
                  "name": "cpAboutCard",
                  "width": "fill_container",
                  "fill": "#FFFFFF",
                  "cornerRadius": 20,
                  "layout": "vertical",
                  "gap": 20,
                  "padding": 40,
                  "children": [
                    {
                      "type": "text",
                      "id": "W1UWJ",
                      "name": "cpAboutH2a",
                      "fill": "#0F172A",
                      "content": "The problem",
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "CCufj",
                      "name": "cpAboutP1",
                      "fill": "#0F172A",
                      "content": "Remote workers face a banking nightmare. Traditional banks require a fixed address. Crypto solutions are powerful but complex. Neither works when you're building from Bali this month and Lisbon next.",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "GLvYz",
                      "name": "cpAboutH2b",
                      "fill": "#0F172A",
                      "content": "Our solution",
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "wXwxg",
                      "name": "cpAboutP2",
                      "fill": "#0F172A",
                      "content": "Nomad is a banking layer on Solana. Hold balances in USDC, EUR, GBP, KZT. Receive salary from any employer. Spend with a card. Off-ramp to local currency — no predatory fees, no bank demanding a local address.",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "Ygxpb",
                      "name": "cpAboutImg",
                      "width": "fill_container",
                      "height": 280,
                      "fill": {
                        "type": "image",
                        "enabled": true,
                        "url": "./images/generated-1776776517789.png",
                        "mode": "fill"
                      },
                      "cornerRadius": 12
                    },
                    {
                      "type": "text",
                      "id": "y28aO",
                      "name": "cpAboutH2c",
                      "fill": "#0F172A",
                      "content": "Why now",
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "VoeA6",
                      "name": "cpAboutP3",
                      "fill": "#0F172A",
                      "content": "The remote workforce is exploding. 35+ million digital nomads globally. Solana's fees make micropayments viable. USDC is regulated and reliable. The pieces are finally in place.",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "ngyMe",
                  "name": "cpRisksCard",
                  "width": "fill_container",
                  "fill": "#FEF3C7",
                  "cornerRadius": 20,
                  "layout": "vertical",
                  "gap": 12,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "B1iPB",
                      "name": "cpRisksT",
                      "fill": "#78350F",
                      "content": "⚠️  Risks & Challenges",
                      "fontFamily": "Inter",
                      "fontSize": 20,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "2XPHE",
                      "name": "cpRisksP",
                      "fill": "#92400E",
                      "content": "Banking regulations vary dramatically by country. Card issuance may be delayed in certain regions. Early version will focus on USDC rails only. We're building in public and will share every obstacle transparently.",
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },

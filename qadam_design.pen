                },
                {
                  "type": "text",
                  "id": "cRZft",
                  "name": "intro",
                  "fill": "#374151",
                  "textGrowth": "fixed-width",
                  "width": "fill_container",
                  "content": "Nomad is building a banking layer for the 35 million people who work from anywhere. Multi-currency accounts, instant crypto off-ramps, and borderless transfers — all on Solana rails for fast, near-zero fees.",
                  "lineHeight": 1.55,
                  "fontFamily": "Inter",
                  "fontSize": 18,
                  "fontWeight": "normal"
                },
                {
                  "type": "frame",
                  "id": "s50P8",
                  "name": "sec1",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 10,
                  "children": [
                    {
                      "type": "text",
                      "id": "88yRm",
                      "name": "sec1h",
                      "fill": "#0F172A",
                      "content": "The problem",
                      "fontFamily": "Inter",
                      "fontSize": 22,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "Aye3U",
                      "name": "sec1p",
                      "fill": "#4B5563",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Remote workers face a banking nightmare. Traditional banks require a fixed address. Crypto solutions are powerful but unfriendly. Getting paid in one country and spending in another means fees, delays, and constant friction.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "AuooM",
                  "name": "sec2",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 10,
                  "children": [
                    {
                      "type": "text",
                      "id": "6uhc3",
                      "name": "sec2h",
                      "fill": "#0F172A",
                      "content": "Our solution",
                      "fontFamily": "Inter",
                      "fontSize": 22,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "Hx7TP",
                      "name": "sec2p",
                      "fill": "#4B5563",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Nomad is a banking layer on Solana. Hold balances in USDC, EUR, GBP, KZT. Receive salary from any employer. Spend anywhere with a Visa card. Move between currencies in seconds with zero hidden fees.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "itDHC",
                      "name": "sec2img",
                      "clip": true,
                      "width": "fill_container",
                      "height": 280,
                      "fill": {
                        "type": "image",
                        "enabled": true,
                        "url": "./images/generated-1776926489329.png",
                        "mode": "fill"
                      },
                      "cornerRadius": 16,
                      "stroke": {
                        "thickness": 1,
                        "fill": "#0000000A"
                      }
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "JO2EX",
                  "name": "sec3",
                  "width": "fill_container",
                  "layout": "vertical",
                  "gap": 10,
                  "children": [
                    {
                      "type": "text",
                      "id": "XFBn5",
                      "name": "sec3h",
                      "fill": "#0F172A",
                      "content": "Why now",
                      "fontFamily": "Inter",
                      "fontSize": 22,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "outrz",
                      "name": "sec3p",
                      "fill": "#4B5563",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "The remote workforce is exploding. 35+ million digital nomads globally. Solana's sub-second finality and near-zero fees make micropayments viable for the first time. USDC is regulated and reliable. The pieces are finally in place.",
                      "lineHeight": 1.6,
                      "fontFamily": "Inter",
                      "fontSize": 15,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "v8gzJ",
                  "name": "risks",
                  "width": "fill_container",
                  "fill": "#FEF3C7",
                  "cornerRadius": 12,

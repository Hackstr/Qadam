                {
                  "type": "frame",
                  "id": "unIRr",
                  "name": "ws4Content",
                  "width": "fill_container",
                  "fill": "#FFFFFF",
                  "cornerRadius": 16,
                  "layout": "vertical",
                  "gap": 20,
                  "padding": 32,
                  "children": [
                    {
                      "type": "text",
                      "id": "7wnON",
                      "name": "ws4ContentH",
                      "fill": "#0F172A",
                      "content": "About this project",
                      "fontFamily": "Inter",
                      "fontSize": 24,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "xP7DN",
                      "name": "ws4ContentP1",
                      "fill": "#0F172A",
                      "content": "Remote workers face a banking nightmare. Traditional banks demand a fixed address. Crypto solutions are complex. Nomad bridges the gap — one account, any country, any currency.",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "DPg7i",
                      "name": "ws4ContentP2",
                      "fill": "#0F172A",
                      "content": "We're building a banking layer on Solana that lets remote workers hold balances in USDC, EUR, GBP, KZT — receive transfers from employers, spend with a card, and off-ramp to local currencies without predatory fees.",
                      "fontFamily": "Inter",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "EkBoA",
                      "name": "ws4Risks",
                      "width": "fill_container",
                      "fill": "#FEF3C7",
                      "cornerRadius": 12,
                      "layout": "vertical",
                      "gap": 8,
                      "padding": 20,

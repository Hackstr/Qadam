                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "700"
                        },
                        {
                          "type": "text",
                          "id": "tg5zs",
                          "name": "ws4RisksP",
                          "fill": "#92400E",
                          "content": "Banking regulations vary dramatically by country. We may need to delay card issuance in specific regions. Early version will focus on USDC rails first.",
                          "fontFamily": "Inter",
                          "fontSize": 14,
                          "fontWeight": "normal"
                        }
                      ]

[Unit]
Description=Qadam Frontend (Next.js)
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/qadam/qadam_frontend
EnvironmentFile=/home/ubuntu/qadam/.env.production
ExecStart=/usr/bin/npx next start -p 3000
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=qadam-frontend

[Install]
WantedBy=multi-user.target
